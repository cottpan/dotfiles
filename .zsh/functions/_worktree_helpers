#!/usr/bin/env zsh
#
# Shared helpers for worktree creation functions

__worktree_config_find_depth=6

__worktree_find_config_files() {
  local git_root="$1"
  find "$git_root" -maxdepth "$__worktree_config_find_depth" \
    \( -name ".env*" -o -name ".mise.local.toml" \) -type f 2>/dev/null
}

__worktree_copy_config_files() {
  local git_root="$1"
  local worktree_path="$2"
  local config_files
  config_files=$(__worktree_find_config_files "$git_root")

  if [ -z "$config_files" ]; then
    return 0
  fi

  echo ""
  echo "📄 Found config files in main repository:"
  echo "$config_files" | while read -r config_file; do
    local rel_path=${config_file#$git_root/}
    echo "   $rel_path"
  done
  echo ""
  echo "📋 Copy config files to new worktree? [y/N]:"
  read -q copy_config
  echo ""

  if [[ "$copy_config" != "y" ]]; then
    echo "⏭️  Skipped copying config files"
    return 0
  fi

  echo "$config_files" | while read -r config_file; do
    local rel_path=${config_file#$git_root/}
    local target_file="$worktree_path/$rel_path"
    local target_dir
    target_dir=$(dirname "$target_file")

    if [ ! -d "$target_dir" ]; then
      mkdir -p "$target_dir"
    fi

    if cp "$config_file" "$target_file"; then
      echo "   ✅ Copied: $rel_path"
    else
      echo "   ❌ Failed to copy: $rel_path"
    fi
  done
}

__worktree_run_project_setup() {
  local worktree_path="$1"
  local project_name="$2"
  local setup_dir setup_cmd

  case "$project_name" in
    dresscode-backend)
      setup_dir="$worktree_path/v2"
      setup_cmd=(make refresh)
      ;;
    dresscode-frontend)
      setup_dir="$worktree_path"
      setup_cmd=(pnpm i)
      ;;
    *)
      return 0
      ;;
  esac

  if [ ! -d "$setup_dir" ]; then
    echo "⚠️  Setup directory not found: $setup_dir"
    return 1
  fi

  local setup_rel="."
  if [[ "$setup_dir" != "$worktree_path" ]]; then
    setup_rel="${setup_dir#$worktree_path/}"
  fi

  echo ""
  echo "🔧 Run '${setup_cmd[*]}' in ${setup_rel}? [y/N]:"
  read -q run_setup
  echo ""

  if [[ "$run_setup" != "y" ]]; then
    echo "⏭️  Skipped project setup"
    return 0
  fi

  echo "Use mise exec? [y/N]:"
  read -q use_mise
  echo ""

  local cmd=( "${setup_cmd[@]}" )
  if [[ "$use_mise" == "y" ]]; then
    cmd=(mise exec -- "${setup_cmd[@]}")
  fi

  echo "🚀 Running: (cd ${setup_rel} && ${cmd[*]})"
  if (cd "$setup_dir" && "${cmd[@]}"); then
    echo "✅ Project setup completed"
  else
    echo "❌ Project setup failed"
    return 1
  fi
}
